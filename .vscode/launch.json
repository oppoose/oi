{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug C",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            //"console": "integratedTerminal",  // 改为集成终端避免编码问题
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\mingw64\\bin\\gdb.exe", // 修改为你的实际路径
            "preLaunchTask": "Build C",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set charset to UTF-8",
                    "text": "set charset UTF-8",
                    "ignoreFailures": true
                },
                {
                    "description": "Set host charset to UTF-8",
                    "text": "set host-charset UTF-8",
                    "ignoreFailures": true
                },
                {
                    "description": "Set target charset to UTF-8",
                    "text": "set target-charset UTF-8",
                    "ignoreFailures": true
                }
            ],
            "environment": [
                {"name": "LC_ALL", "value": "C.UTF-8"},
                {"name": "PYTHONUNBUFFERED", "value": "1"}
            ]
        },
        {
            "name": "Debug OpenCV",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            //"console": "integratedTerminal",  // 改为集成终端避免编码问题
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\mingw64\\bin\\gdb.exe",
            "preLaunchTask": "Build OpenCV",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set charset to UTF-8",
                    "text": "set charset UTF-8",
                    "ignoreFailures": true
                },
                {
                    "description": "Set host charset to UTF-8",
                    "text": "set host-charset UTF-8",
                    "ignoreFailures": true
                },
                {
                    "description": "Set target charset to UTF-8",
                    "text": "set target-charset UTF-8",
                    "ignoreFailures": true
                }
            ],
            "environment": [
                {"name": "LC_ALL", "value": "C.UTF-8"},
                {
                    "name": "PATH",
                    "value": "C:\\opencv\\build\\x64\\vc16\\bin;${env:PATH}"
                }
            ]
        },
        {
            "name": "Debug C++ (MSVC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",  // 使用集成终端
            "preLaunchTask": "C/C++: cl.exe 生成活动文件"
        }
    ]
}